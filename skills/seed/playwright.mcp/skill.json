{
    "id": "playwright.mcp",
    "kind": "seed",
    "description": "Browser automation via Playwright MCP server. Navigate websites, click elements, fill forms, extract data, take screenshots, and perform full browser automation workflows.",
    "skillDomains": ["literature", "web-automation"],
    "inputContract": {
        "prompt": "Natural language browser automation task. The skill uses Playwright MCP tools: browser_navigate, browser_click, browser_type, browser_select_option, browser_get_text, browser_evaluate, browser_snapshot, browser_close, browser_choose_file, browser_press."
    },
    "outputArtifactSchema": {
        "type": "browser-automation-result",
        "required": ["result", "actions", "screenshots"]
    },
    "entrypoint": {
        "type": "agentserver-generation"
    },
    "environment": {
        "language": "python",
        "dependencies": ["python>=3.10"],
        "binaries": ["playwright-mcp", "npx"],
        "network": ["*"],
        "execution": "AgentServer generates workspace-local task code at runtime."
    },
    "metadata": {
        "source": "clawhub",
        "clawhubId": "spiceman161/playwright-mcp",
        "npmPackage": "@playwright/mcp",
        "version": "0.0.72",
        "installCommand": "npm install -g @playwright/mcp",
        "browserInstallCommand": "playwright install chromium",
        "os": ["linux", "darwin", "win32"],
        "securityVerdict": "clean",
        "mcpTools": [
            "browser_navigate", "browser_click", "browser_type",
            "browser_select_option", "browser_get_text", "browser_evaluate",
            "browser_snapshot", "browser_close", "browser_choose_file", "browser_press"
        ]
    },
    "validationSmoke": {
        "command": "playwright-mcp --version",
        "expectedOutput": "0.0.72"
    }
}
