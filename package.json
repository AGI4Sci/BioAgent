{
  "name": "@agi4sci/bioagent-web-ui",
  "version": "0.1.0",
  "description": "BioAgent React web UI and design documentation.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx tools/dev.ts",
    "dev:ui": "vite --host 0.0.0.0",
    "build": "vite build",
    "test": "node --import tsx --test \"src/ui/src/**/*.test.ts\"",
    "verify": "npm run typecheck && npm run test && npm run smoke:all && npm run build",
    "smoke:all": "npm run smoke:fixtures && npm run smoke:skill-registry && npm run smoke:seed-runtime && npm run smoke:knowledge-unsupported && npm run smoke:repair && npm run smoke:agentserver-generation && npm run smoke:agentserver-repair && npm run smoke:workspace-agentserver-repair && npm run smoke:view && npm run smoke:runtime-ui-manifest && npm run smoke:omics-runners",
    "smoke:fixtures": "tsx tests/smoke/smoke-bioagent-fixtures.ts",
    "smoke:repair": "tsx tests/smoke/smoke-repair-needed.ts",
    "smoke:agentserver-generation": "tsx tests/smoke/smoke-agentserver-generation.ts",
    "smoke:agentserver-repair": "tsx tests/smoke/smoke-agentserver-repair.ts",
    "smoke:workspace-agentserver-repair": "tsx tests/smoke/smoke-workspace-server-agentserver-repair.ts",
    "smoke:skill-registry": "tsx tests/smoke/smoke-skill-registry.ts",
    "smoke:scp-skills": "tsx tests/smoke/smoke-scp-skills.ts",
    "smoke:tools-skills-diverse": "tsx tests/smoke/smoke-tools-skills-diverse.ts",
    "smoke:scp-live-skills": "tsx tests/smoke/smoke-scp-live-skills.ts",
    "smoke:scp-live-capability": "tsx tests/smoke/smoke-scp-live-capability.ts",
    "smoke:seed-runtime": "tsx tests/smoke/smoke-seed-runtime.ts",
    "smoke:knowledge-unsupported": "tsx tests/smoke/smoke-knowledge-unsupported.ts",
    "smoke:view": "tsx tests/smoke/smoke-view-composition.ts",
    "smoke:runtime-ui-manifest": "tsx tests/smoke/smoke-runtime-ui-manifest.ts",
    "smoke:blastp-runtime": "tsx tests/smoke/smoke-blastp-runtime.ts",
    "smoke:omics-runners": "tsx tests/smoke/smoke-omics-runners.ts",
    "workspace:server": "tsx src/runtime/workspace-server.ts",
    "bench:models": "tsx tools/benchmark-model-speed.ts",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "3dmol": "^2.5.4",
    "d3": "^7.9.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
