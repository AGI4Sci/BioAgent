{
  "id": "knowledge.uniprot_chembl_lookup",
  "kind": "seed",
  "description": "Query UniProt for reviewed human gene/protein records or ChEMBL for compound mechanism and indication records.",
  "profiles": ["knowledge"],
  "inputContract": {
    "prompt": "Gene, protein, accession, compound, inhibitor, or drug query."
  },
  "outputArtifactSchema": {
    "type": "knowledge-graph",
    "required": ["nodes", "edges", "rows", "sourceRefs"]
  },
  "entrypoint": {
    "type": "workspace-task",
    "command": "python",
    "path": "../../../scripts/python_tasks/knowledge_lookup_task.py"
  },
  "environment": {
    "language": "python",
    "dependencies": ["python>=3.10", "urllib.request", "json"],
    "network": ["https://rest.uniprot.org", "https://www.ebi.ac.uk/chembl"],
    "migrationStatus": "workspace task"
  },
  "validationSmoke": {
    "mode": "workspace-task",
    "prompt": "TP53 gene",
    "expectedArtifactType": "knowledge-graph"
  },
  "examplePrompts": [
    "TP53 gene",
    "sotorasib compound ChEMBL",
    "P04637 UniProt protein"
  ],
  "promotionHistory": []
}
