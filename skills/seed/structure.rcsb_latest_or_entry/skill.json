{
  "id": "structure.rcsb_latest_or_entry",
  "kind": "seed",
  "description": "Fetch the latest matching RCSB structure or a requested PDB/AlphaFold entry, write coordinates and return a structure-summary artifact.",
  "profiles": ["structure"],
  "inputContract": {
    "prompt": "Free text containing a PDB id, UniProt accession, gene/protein name, residue range, or latest-structure request.",
    "workspacePath": "Writable BioAgent workspace."
  },
  "outputArtifactSchema": {
    "type": "structure-summary",
    "required": ["id", "type", "producerAgent", "schemaVersion", "metadata", "data"]
  },
  "entrypoint": {
    "type": "workspace-task",
    "command": "python",
    "path": "../../../scripts/python_tasks/structure_task.py"
  },
  "environment": {
    "language": "python",
    "dependencies": ["python>=3.10", "urllib.request", "json"],
    "network": ["https://data.rcsb.org", "https://files.rcsb.org", "https://alphafold.ebi.ac.uk"]
  },
  "validationSmoke": {
    "mode": "manifest",
    "prompt": "PDB 7BZ5 residues 142-158",
    "expectedArtifactType": "structure-summary"
  },
  "examplePrompts": [
    "PDB 7BZ5 residues 142-158",
    "Find the latest RCSB structure for TP53 DNA binding domain",
    "AlphaFold structure for P04637"
  ],
  "promotionHistory": [],
  "scopeDeclaration": {
    "supportedTasks": ["RCSB entry fetch", "RCSB search", "AlphaFold DB lookup", "coordinate artifact generation"],
    "requiredInputs": ["Protein/gene/accession/PDB id prompt"],
    "unsupportedTasks": ["Molecular dynamics", "binding free energy calculation", "de novo structure prediction"]
  }
}

