{
  "id": "sequence.ncbi_blastp_search",
  "kind": "seed",
  "description": "Run real NCBI BLASTP sequence similarity searches for protein sequences and return tabular alignment hits.",
  "skillDomains": ["knowledge"],
  "inputContract": {
    "prompt": "Protein sequence or FASTA text, optional database=swissprot/nr and hitlist size."
  },
  "outputArtifactSchema": {
    "type": "sequence-alignment",
    "required": ["rows", "alignments", "program", "database", "rid"]
  },
  "entrypoint": {
    "type": "workspace-task",
    "command": "python",
    "path": "../../../src/runtime/python_tasks/blastp_task.py"
  },
  "environment": {
    "language": "python",
    "dependencies": ["python>=3.10", "urllib.request", "xml.etree.ElementTree"],
    "network": ["https://blast.ncbi.nlm.nih.gov/Blast.cgi"],
    "migrationStatus": "workspace task"
  },
  "validationSmoke": {
    "mode": "workspace-task",
    "prompt": "BLASTP sequence=MALWMRLLPLLALLALWGPDPAAAFVNQHLCGSHLVEALYLVCGERGFFYTPKT database=swissprot hitlist=5",
    "expectedArtifactType": "sequence-alignment"
  },
  "examplePrompts": [
    "BLASTP protein sequence alignment",
    "sequence=MALWMRLLPLLALLALWGPDPAAAFVNQHLCGSHLVEALYLVCGERGFFYTPKT database=swissprot",
    "protein BLAST result table"
  ],
  "promotionHistory": []
}
